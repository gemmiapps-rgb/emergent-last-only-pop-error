{
  "expo": {
    "name": "CricApp",
    "slug": "cric-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "cricapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "owner": "gemmibuild",
    "extra": {
      "privacyPolicyUrl": "https://docs.google.com/document/d/19XEkcDpBb-W2x6wZo0a23ygVw7BB1uuAZOacq_3U_u8/edit?usp=drivesdk",
      "router": {},
      "backendUrl": "https://scoreboard-pro-21.preview.emergentagent.com",
      "admob": {
        "appId": "ca-app-pub-9675798593675825~2399929714",
        "appOpenAdId": "ca-app-pub-9675798593675825/4826782503",
        "bannerAdId": "ca-app-pub-9675798593675825/8616886104",
        "interstitialAdId": "ca-app-pub-9675798593675825/8438724452",
        "rewardedAdId": "ca-app-pub-9675798593675825/6702740458",
        "testDeviceId": "553c7721-4821-461b-9f62-8584b1e60745"
      },
      "eas": {
        "projectId": "47d65cb3-f161-4591-bbd9-9d062e96ca5d"
      }
    },
    "react-native-google-mobile-ads": {
      "android_app_id": "ca-app-pub-9675798593675825~2399929714",
      "ios_app_id": "ca-app-pub-3940256099942544~1458002511"
    },
    "splash": {
      "image": "./assets/splash_doodle.png",
      "resizeMode": "contain",
      "backgroundColor": "#f5f5dc"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#f5f5dc"
      },
      "package": "com.mycricapp.live",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-splash-screen",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24,
            "extraProguardRules": "-keep class com.google.android.gms.internal.consent_sdk.** { *; }"
          }
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-9675798593675825~2399929714",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/logo.png",
          "color": "#4CAF50",
          "defaultChannel": "match-alerts"
        }
      ],
      "expo-asset",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
